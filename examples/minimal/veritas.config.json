{
  "topic": "Espresso brewing",
  "domains": ["extraction", "grind", "machine", "beans", "water", "milk"],

  "oracle": { "type": "none", "ref": "" },

  "sources": [
    { "type": "files", "config": { "path": "raw/**/*.json" } },
    {
      "type": "interview",
      "config": { "path": "raw/interviews/*.md", "domain": "extraction" }
    }
  ],

  "compute": {
    "collect": {
      "baseURL": "https://openrouter.ai/api/v1",
      "model": "google/gemini-2.5-flash-lite",
      "keyEnv": "OPENROUTER_API_KEY"
    },
    "analyze": {
      "baseURL": "https://openrouter.ai/api/v1",
      "model": "anthropic/claude-haiku-4.5",
      "keyEnv": "OPENROUTER_API_KEY"
    },
    "judge": {
      "baseURL": "https://openrouter.ai/api/v1",
      "model": "anthropic/claude-sonnet-4.5",
      "keyEnv": "OPENROUTER_API_KEY"
    },
    "serve": {
      "baseURL": "https://openrouter.ai/api/v1",
      "model": "anthropic/claude-haiku-4.5",
      "keyEnv": "OPENROUTER_API_KEY"
    }
  },

  "parallelism": { "waves": 3, "chunkChars": 12000 },
  "language": "en",
  "out": "out",

  "healthPing": {
    "enabled": false,
    "intervalMinutes": 1440,
    "canaries": ["What grind change fixes a sour shot?"]
  }
}
