# Copy to .env and fill. .env is gitignored — never commit real keys.
# The keyEnv names below must match your veritas.config.json compute tiers.

# Cheap tier — collection (extraction) + vision (reading charts/images)
COLLECT_KEY=

# Strong tier — analysis (synthesis, verification, discovery)
ANALYZE_KEY=

# Runtime tier — the answering AI
SERVE_KEY=

# Source-specific secrets (only if you use these collectors)
# DISCORD_TOKEN=
# GITHUB_TOKEN=

# OpenRouter (all tiers can share one key)
OPENROUTER_API_KEY=
